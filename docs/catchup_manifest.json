{
  "version": 2,
  "owners": [
    "web",
    "android",
    "agent"
  ],
  "refreshPolicy": {
    "runAfterStructureChange": true,
    "reviewEveryMonths": 6
  },
  "excludeTopLevelDirectories": [
    ".git",
    "vendor",
    ".idea",
    ".gradle",
    ".kotlin",
    ".claude",
    ".phpunit.cache",
    "_archive",
    "_deploy_tmp",
    "_tmp_ux_test_env",
    "android-shell",
    "CLI-Anything",
    "output",
    "upload_package"
  ],
  "excludePathPrefixes": [
    "docs/archive/"
  ],
  "scaleItems": [
    {
      "label": "Current app routes",
      "path": "platform_v2/src/routes",
      "filter": "*.ts",
      "recurse": true
    },
    {
      "label": "Current app services",
      "path": "platform_v2/src/services",
      "filter": "*.ts",
      "recurse": true
    },
    {
      "label": "Current app UI helpers",
      "path": "platform_v2/src/ui",
      "filter": "*.ts",
      "recurse": true
    },
    {
      "label": "Current app content files",
      "path": "platform_v2/src/content",
      "filter": "*",
      "recurse": true
    },
    {
      "label": "Current app tests",
      "path": "platform_v2/src",
      "filter": "*.test.ts",
      "recurse": true
    },
    {
      "label": "Current app E2E specs",
      "path": "platform_v2/e2e",
      "filter": "*.ts",
      "recurse": true
    },
    {
      "label": "Database migrations",
      "path": "platform_v2/db/migrations",
      "filter": "*.sql",
      "recurse": false
    },
    {
      "label": "Android source files",
      "path": "mobile/android/ikimon-pocket/app/src/main",
      "filter": "*.kt",
      "recurse": true
    }
  ],
  "sections": [
    {
      "title": "Top-Level Directories",
      "mode": "top_level_directories"
    },
    {
      "title": "Current App Source Areas",
      "mode": "directory_count",
      "path": "platform_v2/src",
      "filter": "*.ts"
    },
    {
      "title": "Largest Route Files",
      "mode": "largest_files",
      "path": "platform_v2/src/routes",
      "filter": "*.ts",
      "limit": 10
    },
    {
      "title": "Largest Service Files",
      "mode": "largest_files",
      "path": "platform_v2/src/services",
      "filter": "*.ts",
      "limit": 10
    }
  ],
  "entryPoints": [
    {
      "path": "platform_v2/src/routes/",
      "role": "pages and API routes"
    },
    {
      "path": "platform_v2/src/services/",
      "role": "domain services"
    },
    {
      "path": "platform_v2/src/ui/",
      "role": "UI rendering helpers"
    },
    {
      "path": "platform_v2/src/content/",
      "role": "public copy and longform content"
    },
    {
      "path": "platform_v2/db/migrations/",
      "role": "canonical database migrations"
    },
    {
      "path": "platform_v2/src/legacy/",
      "role": "compatibility boundary from the current app"
    },
    {
      "path": "platform_v2/e2e/",
      "role": "browser QA specs"
    },
    {
      "path": "mobile/android/ikimon-pocket/",
      "role": "Android shell"
    }
  ],
  "workspace": {
    "file": "ikimon.life.code-workspace",
    "folders": [
      {
        "name": "shared-root",
        "path": "."
      },
      {
        "name": "current-app",
        "path": "platform_v2"
      },
      {
        "name": "docs",
        "path": "docs"
      },
      {
        "name": "ops",
        "path": "ops"
      },
      {
        "name": "repo-scripts",
        "path": "scripts"
      },
      {
        "name": "android-app",
        "path": "mobile/android/ikimon-pocket"
      }
    ],
    "settings": {
      "remote.autoForwardPorts": false,
      "remote.portsAttributes": {
        "8080": {
          "label": "ikimon Current App",
          "onAutoForward": "openBrowserOnce"
        }
      },
      "files.exclude": {
        "**/.DS_Store": true,
        "**/.phpunit.cache": true,
        "upload_package": true
      }
    }
  },
  "watchItems": [
    "When adding a new stable current-app entry point, update entryPoints in this manifest.",
    "When adding a support directory, decide whether it should be excluded from the snapshot.",
    "Keep docs/CATCHUP_GUIDE.md and ikimon.life.code-workspace aligned with this manifest.",
    "Do not add old PHP paths as normal entry points; list them only through a proven compatibility boundary."
  ]
}
