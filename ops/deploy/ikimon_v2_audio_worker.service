[Unit]
Description=ikimon platform_v2 audio detection and fingerprint embedding worker
After=network-online.target birdnet-v3.service

[Service]
Type=oneshot
User=root
WorkingDirectory=/var/www/ikimon.life/repo
ExecStart=/var/www/ikimon.life/repo/ops/cron/run_v2_node_script.sh processAudioSegments --limit=20 --birdnet-url=http://127.0.0.1:8101/analyze --min-confidence=0.25
Nice=8
