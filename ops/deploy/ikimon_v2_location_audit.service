[Unit]
Description=ikimon platform_v2 observation location anomaly audit
After=network-online.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/var/www/ikimon.life/repo
ExecStart=/var/www/ikimon.life/repo/ops/cron/run_v2_node_script.sh auditObservationLocations --since-days=14 --limit=2000 --notify --fail-on-anomaly
Nice=10

