    "upload_package/data/sessions/**",
    "upload_package/data/sites/**",
    "upload_package/data/streaks/**",
    "upload_package/data/surveys/**",
    "upload_package/data/system/**",
    "upload_package/data/taxonomy/**",
    "upload_package/data/tracks/**",
    "upload_package/data/twin_snapshots/**",
    "upload_package/data/uploads/**",
    "upload_package/data/user_badges/**",
    "upload_package/data/user_events/**",
    "upload_package/data/api_keys.json",
    "upload_package/data/auth_bridge_tokens.json",
    "upload_package/data/auth_tokens.json",
    "upload_package/data/bioscan_installs.json",
    "upload_package/data/community_signals.json",
    "upload_package/data/corporations.json",
    "upload_package/data/events.json",
    "upload_package/data/fieldscan_app_tokens.json",
    "upload_package/data/fieldscan_installs.json",
    "upload_package/data/fieldscan_oauth_states.json",
    "upload_package/data/flags.json",
    "upload_package/data/invasive.json",
    "upload_package/data/invites.json",
    "upload_package/data/navigator_data.json",
    "upload_package/data/notifications.json",
    "upload_package/data/observations.json",
    "upload_package/data/redlist.json",
    "upload_package/data/redlist_mapping.json",
    "upload_package/data/taxa_cache.json",
    "upload_package/data/taxon_resolver.json",
    "upload_package/data/taxon_search_cache.json",
    "upload_package/data/users.json",
    "upload_package/data/geo_cache.sqlite3",
    "upload_package/data/ikimon.db",
    "upload_package/data/master_extraction_queue.sqlite3",
    "upload_package/data/weather_cache.sqlite3",
    "upload_package/data/*.db",
    "upload_package/data/*.sqlite3-shm",
    "upload_package/data/*.sqlite3-wal",
    "upload_package/config/secret.php",
    "upload_package/config/oauth_config.php",
    "upload_package/config/config.php"
  ],
  "trackedStaticDataPaths": [
    "upload_package/data/.htaccess",
    "upload_package/data/config/**",
    "upload_package/data/dwca/**",
    "upload_package/data/ecology/**",
    "upload_package/data/redlists/**"
  ],
  "healthChecks": [
    "http://127.0.0.1:8081/index.php",
    "http://127.0.0.1:8081/explore.php",
    "http://127.0.0.1:8081/post.php",
    "http://127.0.0.1:8081/api/get_events.php"
  ],
  "notes": [
    "Preferred staging URL is https://staging.ikimon.life/ behind HTTPS + basic auth + noindex.",
    "sslip.io is only a fallback review endpoint and should not be treated as the formal staging hostname.",
    "Initial staging data is copied from production before any redesign work is deployed.",
    "Tracked static data under upload_package/data/.htaccess, config, dwca, ecology, and tracked redlists must stay deployable.",
    "Uploads are stored outside the staging repo and symlinked into public_html/uploads.",
    "Developer machines do not need hosts overrides because sslip.io resolves the VPS IP automatically.",
    "Analytics and service worker are disabled on staging so review traffic does not pollute production telemetry."
  ]
}
