  "stagingListenHost": "0.0.0.0",
  "stagingListenPort": 8081,
  "stagingBaseUrl": "https://staging.ikimon.life/",
  "runtimePersistentAllowlistPath": "ops/deploy/runtime_persistent_allowlist.txt",
  "sourceProductionRoot": "/var/www/ikimon.life",
