// define('NOINDEX_SITE_OVERRIDE', false);

if (!defined('GEMINI_API_KEY_SECRET')) {
    define('GEMINI_API_KEY_SECRET', '');
}

if (!defined('OPENAI_API_KEY_SECRET')) {
    define('OPENAI_API_KEY_SECRET', '');
}

if (!defined('GOOGLE_CLIENT_ID')) {
    define('GOOGLE_CLIENT_ID', '');
}

if (!defined('GOOGLE_CLIENT_SECRET')) {
    define('GOOGLE_CLIENT_SECRET', '');
}

if (!defined('TWITTER_CLIENT_ID')) {
    define('TWITTER_CLIENT_ID', '');
}

if (!defined('TWITTER_CLIENT_SECRET')) {
