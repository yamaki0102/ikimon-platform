# Custom Error Pages
ErrorDocument 403 /403.php
ErrorDocument 404 /404.php

# Enable Gzip Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Browser Caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# Security Headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Frame-Options "SAMEORIGIN"
</IfModule>

# Restrict dev/debug files to local access only
<FilesMatch "^(dev_admin_login|diag_profile|csrf_debug|test_concurrency)\.php$">
    Require local
</FilesMatch>

# Clean URL Rewrite Rules
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # /species/{slug} → species.php?name={slug}
    RewriteRule ^species/([a-z0-9\-]+)/?$ species.php?name=$1 [L,QSA]

    # /obs/{id} → observation_detail.php?id={id}
    RewriteRule ^obs/([a-zA-Z0-9_\-]+)/?$ observation_detail.php?id=$1 [L,QSA]

    # /site/{id} → site_dashboard.php?id={id}
    RewriteRule ^site/([a-zA-Z0-9_\-]+)/?$ site_dashboard.php?id=$1 [L,QSA]

    # /user/{id} → profile.php?id={id}
    RewriteRule ^user/([a-zA-Z0-9_\-]+)/?$ profile.php?id=$1 [L,QSA]
</IfModule>
