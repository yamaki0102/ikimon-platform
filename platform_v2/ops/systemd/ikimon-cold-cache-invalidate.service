[Unit]
Description=ikimon Freshness OS — user_output_cache GC + freshness_registry status refresh
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=oneshot
User=ikimon-staging
Group=www-data
WorkingDirectory=/var/www/ikimon.life-staging/repo/platform_v2
EnvironmentFile=/etc/ikimon/staging-v2.env
ExecStart=/usr/bin/env node dist/scripts/cron/runCacheInvalidate.js
StandardOutput=journal
StandardError=journal
TimeoutStartSec=120
