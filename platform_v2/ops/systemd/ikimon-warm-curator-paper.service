[Unit]
Description=ikimon Freshness OS — paper-research-curator (Node scheduled run)
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=oneshot
User=ikimon-staging
Group=www-data
WorkingDirectory=/var/www/ikimon.life-staging/repo/platform_v2
EnvironmentFile=/etc/ikimon/staging-v2.env
Environment=CURATOR_NAME=paper-research
ExecStart=/usr/bin/env node dist/scripts/cron/runCurator.js
StandardOutput=journal
StandardError=journal
TimeoutStartSec=3600
