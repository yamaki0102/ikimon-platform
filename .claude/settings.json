{
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(php -l*)",
      "Bash(php -S localhost*)",
      "Bash(php tools/lint*)",
      "Bash(composer test*)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(curl *)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)"
    ]
  }
}
