{
  "permissions": {
    "allow": [
      "Bash(*)",
      "mcp__pencil",
      "mcp__Claude_in_Chrome__*",
      "mcp__Claude_Preview__*"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf C:/*)",
      "Bash(rm -rf ~*)",
      "Bash(git push --force*)",
      "Bash(git push * --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git checkout -- .)",
      "Bash(git restore .)",
      "Bash(drop database*)",
      "Bash(DROP DATABASE*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/hooks/block-no-verify.sh",
            "description": "Block --no-verify flag on git commands"
          },
          {
            "type": "command",
            "command": "bash .claude/scripts/hooks/pre-push-gate.sh",
            "description": "AI review gate — blocks git push without passing /code-review"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/hooks/php-lint.sh",
            "description": "Auto PHP syntax check after edit"
          },
          {
            "type": "command",
            "command": "bash .claude/scripts/hooks/php-debug-warn.sh",
            "description": "Warn about debug statements in PHP"
          },
          {
            "type": "command",
            "command": "bash .claude/scripts/hooks/security-check.sh",
            "async": true,
            "description": "Check for PHP security issues"
          }
        ]
      }
    ]
  }
}
